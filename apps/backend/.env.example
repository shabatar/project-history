# All variables use the PT_ prefix.
# Copy to .env and edit as needed.

# PT_DATABASE_URL=sqlite:///data/app.db
# PT_LOG_LEVEL=INFO

# ── Security ──
# Set an API key to require authentication on all endpoints.
# Required if exposing the app to a network.
# PT_API_KEY=your-secret-key-here

# ── Git ──
# SSH key path for cloning private repos (default: system SSH agent)
# PT_SSH_KEY_PATH=~/.ssh/id_ed25519

# ── LLM / Ollama ──
# PT_OLLAMA_BASE_URL=http://localhost:11434
# PT_OLLAMA_CLIENT_MODE=native
# PT_DEFAULT_MODEL=llama3.1

# Summarisation tuning
# PT_SUMMARY_CHUNK_SIZE=80
# PT_SUMMARY_TOKEN_BUDGET=3200
# PT_SUMMARY_TEMPERATURE=0.3

# ── Optional: YouTrack boards ──
# PT_YOUTRACK_ENABLED=false
# PT_YOUTRACK_BASE_URL=https://youtrack.example.com
# Token is optional here — you can also set it via the UI (Boards page),
# stored encrypted at rest. When this env var is set, it takes precedence.
# PT_YOUTRACK_API_TOKEN=perm:your-token-here

# ── Secrets encryption ──
# PT_SECRET_KEY is used to encrypt secrets (YouTrack token) at rest.
# Auto-generated and stored at data/.secret_key (chmod 600) if not set. Generate one with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# PT_SECRET_KEY=
